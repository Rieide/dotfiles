# Public fallback identity. Work or machine-specific identities belong in
# ~/.gitconfig.local and files included from it, never in this repository.
[user]
	name = Rieide
	email = riei.de@outlook.com

# Keep this include after [user] so matching private identity files can
# override the public fallback without exposing their values here.
[include]
	path = ~/.gitconfig.local

[core]
	editor = nvim
	hooksPath = ~/.config/git/hooks
	pager = $HOME/.local/bin/git-delta-pager

[interactive]
	diffFilter = $HOME/.local/bin/git-delta-filter

[delta]
	syntax-theme = Nord
	line-numbers = true
	navigate = true
	side-by-side = true

[diff]
	colorMoved = default

[merge]
	conflictstyle = zdiff3

[pull]
	ff = only

[push]
	default = current

[init]
	defaultBranch = main

[alias]
	st = status --short --branch
	sw = switch
	co = checkout
	br = branch --sort=-committerdate
	lg = log --graph --decorate --date=short --pretty=format:'%C(yellow)%h%Creset %Cgreen%ad%Creset %C(auto)%d%Creset %s %Cblue<%an>%Creset'
	last = log -1 --stat
	changed = diff --name-only
	staged = diff --cached
	unstaged = diff
