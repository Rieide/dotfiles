# 个人构建笔记，不纳入版本控制
NOTES.md

# 机器专属的本地覆盖配置
*local*
local.zsh

# GNU Stow package policy files are shared configuration, not machine-local
# overrides, despite containing "local" in their conventional filename.
!**/.stow-local-ignore

# Shared executable in the Git Stow package; do not let the broad *local*
# machine-override rule hide ~/.local/bin/git-identity-check.
!git/.local/
!git/.local/bin/
!git/.local/bin/git-identity-check

# 操作系统杂项
.DS_Store
Thumbs.db
.nvimlog

# Claude
.claude

# tmux 插件代码由 install.sh 固定版本安装、TPM 只负责加载，不纳入版本控制
tmux/.config/tmux/plugins/
