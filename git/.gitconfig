[user]
	name = Rieide
	email = riei.de@outlook.com

[include]
	path = ~/.gitconfig.local

[core]
	editor = nvim
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	line-numbers = true
	navigate = true
	side-by-side = true

[diff]
	colorMoved = default

[merge]
	conflictstyle = zdiff3

[pull]
	ff = only

[push]
	default = current

[init]
	defaultBranch = main

[alias]
	st = status --short --branch
	sw = switch
	co = checkout
	br = branch --sort=-committerdate
	lg = log --graph --decorate --date=short --pretty=format:'%C(yellow)%h%Creset %Cgreen%ad%Creset %C(auto)%d%Creset %s %Cblue<%an>%Creset'
	last = log -1 --stat
	changed = diff --name-only
	staged = diff --cached
	unstaged = diff
